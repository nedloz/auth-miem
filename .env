# Database (async)
PORT=${AUTH_INTERNAL_PORT}
DATABASE_URL=${AUTH_DATABASE_URL}
REDIS_URL=redis://${REDIS_HOST}:6379/0

# DATABASE_URL=sqlite+aiosqlite:///./auth.db

# JWT
SECRET_KEY=supersecretkey123
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# One-time tokens (minutes)
EMAIL_VERIFY_TOKEN_EXPIRE_MINUTES=1440
MAGIC_LOGIN_TOKEN_EXPIRE_MINUTES=15
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# Email (пока выводим в консоль)
EMAIL_FROM=no-reply@example.com
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=example_user
SMTP_PASSWORD=example_password

# Links
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://127.0.0.1:8000